{
  "name": "@bradford-tech/asc-sdk",
  "version": "0.0.2",
  "description": "TypeScript SDK for the Apple App Store Connect API",
  "keywords": [
    "apple",
    "app-store-connect",
    "appstoreconnect",
    "api",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/bradford-tech/asc-sdk#readme",
  "bugs": {
    "url": "https://github.com/bradford-tech/asc-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bradford-tech/asc-sdk.git",
    "directory": "packages/asc-sdk"
  },
  "license": "MIT",
  "author": "Bradford Technologies <asc-sdk@bradford.tech>",
  "sideEffects": [
    "./dist/client/client.gen.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "generate": "rimraf ./src/client && openapi-ts && node scripts/annotate-sdk.mjs",
    "prepack": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.0",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
